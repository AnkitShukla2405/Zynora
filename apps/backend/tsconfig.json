{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "outDir": "./dist",
    "rootDir": "./",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "lib/apoll-client.ts"]
}